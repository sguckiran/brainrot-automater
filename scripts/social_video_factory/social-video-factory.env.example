# social_video_factory — autopilot environment file (EXAMPLE)
# Copy to /etc/social-video-factory.env and `chmod 600` it (it holds a bot token).
# The systemd service sources this file before each autopilot run.

# --- where the repo + uv live (adjust to your VM) ---------------------------
# Absolute path to the checked-out repo (contains pyproject.toml + social_video_factory/).
SVF_REPO_DIR=/home/svf/brainrot-automater

# --- invisible browser: headed Chromium on a virtual display ----------------
# We run HEADED (better against bot-detection) but on Xvfb's virtual display,
# so nothing ever appears on a physical screen. The xvfb.service owns :99.
DISPLAY=:99
SOCIAL_FACTORY_BROWSER_HEADLESS=false

# --- unattended operation ---------------------------------------------------
# MUST be 0 for unattended runs: otherwise every Nth generation blocks on a
# terminal y/N confirm that no human is there to answer.
SOCIAL_FACTORY_BROWSER_REQUIRE_HUMAN_CONFIRM_EVERY=0

# --- supervised CAPTCHA handling (you solve it; nothing is auto-solved) ------
# When true, a CAPTCHA / verification / consent screen HOLDS the browser open,
# pings you with the noVNC link below, and continues automatically once YOU
# clear it in the live view. If you don't clear it within the timeout, the run
# stops and retries next cycle.
SOCIAL_FACTORY_SUPERVISED_PAUSE=true
SOCIAL_FACTORY_SUPERVISED_PAUSE_TIMEOUT=600
# URL where you view the live browser (the noVNC page). With the SSH tunnel from
# the setup guide this is localhost on your machine; set to a LAN/Tailscale URL
# if you'd rather not tunnel. Included verbatim in the Telegram/Discord alert.
SOCIAL_FACTORY_NOVNC_URL=http://localhost:6080/vnc.html

# Conservative local rate limits (keep LOW for account health). These are the
# defaults; shown here so they're easy to tune.
SOCIAL_FACTORY_BROWSER_MAX_GENERATIONS_PER_HOUR=3
SOCIAL_FACTORY_BROWSER_MAX_GENERATIONS_PER_DAY=20
SOCIAL_FACTORY_BROWSER_MIN_SECONDS_BETWEEN_GENERATIONS=180

# Your Google Flow URL (the page you log into for generation).
SOCIAL_FACTORY_FLOW_URL=https://labs.google/fx/tools/flow
# SOCIAL_FACTORY_GEMINI_URL=https://gemini.google.com/

# Persisted runtime data (jobs, profiles, media, state). Defaults to
# <repo>/.social_video_factory if unset.
# SOCIAL_FACTORY_DATA_DIR=/home/svf/.social_video_factory

# --- notifications (reuses your existing Hermes Telegram bot) ---------------
# Same env vars the Hermes gateway uses. Get the chat id by messaging your bot
# and reading getUpdates, or from your existing Hermes setup.
TELEGRAM_BOT_TOKEN=
TELEGRAM_HOME_CHANNEL=
# TELEGRAM_HOME_CHANNEL_THREAD_ID=
# Optional Discord alternative (a channel webhook URL):
# SOCIAL_FACTORY_DISCORD_WEBHOOK=
