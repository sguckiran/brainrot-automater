#!/usr/bin/env bash
# Friendly launcher: `svf <command>` runs the social_video_factory CLI with the
# env file sourced and the venv selected, from anywhere. Installed to
# /usr/local/bin/svf by setup. Examples:
#   svf doctor
#   svf notify-test
#   svf browser-login --target flow
#   svf autopilot
set -a
[ -f "$HOME/svf-autopilot.env" ] && . "$HOME/svf-autopilot.env"
set +a
cd "$HOME/brainrot-automater" || { echo "repo not found at ~/brainrot-automater" >&2; exit 1; }
exec ./.venv/bin/python -m social_video_factory.cli "$@"
